        {
            "type": "cppbuild",
            "label": "C/C++: gcc.exe build active file",
            "command": "C:\\Users\\admin\\OneDrive\\Documents\\mingw64\\bin\\gcc.exe",
            "args": [
                "-fdiagnostics-color=always",
